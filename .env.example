# 로컬 SQLite (무료, 가입 불필요). 나중에 Postgres로 바꾸려면 이 값만 교체.
DATABASE_URL="file:./dev.db"

# 외부 배포 보호용. 비워두면 로컬처럼 인증 없이 열립니다.
# APP_AUTH_PASSWORD=change-me
# APP_AUTH_SECRET=long-random-string

# (선택) 시세/뉴스 — 나중에 키 발급 시 채우는 자리. 비워둬도 동작.
# FINNHUB_API_KEY=
# KIS_APP_KEY=
# KIS_APP_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# ANTHROPIC_API_KEY=   # 뉴스 AI 요약(없으면 헤드라인 그대로)

# ── 알림 채널 (자세한 설정은 NOTIFY.md) ───────────────────
# 받는사람 이메일 (필수: 이메일 알림 켤 때)
# NOTIFY_EMAIL_TO=you@example.com
# 보내는사람 (선택)
# NOTIFY_EMAIL_FROM=GlobalTrade <no-reply@yourdomain.com>

# 이메일 방법 A) SMTP (Gmail 등). 앱 비밀번호 사용
# SMTP_URL=smtps://your@gmail.com:앱비밀번호@smtp.gmail.com:465
# 이메일 방법 B) Resend (무료 3,000통/월)
# RESEND_API_KEY=re_xxx

# 카카오 "나에게 보내기" (무료)
# KAKAO_ACCESS_TOKEN=...
# KAKAO_REFRESH_TOKEN=...   # 선택: 토큰 자동갱신용
# KAKAO_REST_KEY=...        # 선택: 토큰 자동갱신용

# 푸시 (FCM) — 선택
# FCM_SERVER_KEY=
